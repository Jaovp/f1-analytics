# ─── Dados locais (nunca sobem) ───────────────────────────────────────────────
data/raw/
data/processed/
exports/
!data/raw/**/.gitkeep
!data/processed/.gitkeep
!exports/.gitkeep

# ─── Ambiente e segredos ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ─── Ambientes virtuais ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── FastF1 cache ─────────────────────────────────────────────────────────────
data/raw/fastf1_cache/
!data/raw/fastf1_cache/.gitkeep

# ─── Power BI ─────────────────────────────────────────────────────────────────
*.pbix
*.pbit

# ─── SO ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

